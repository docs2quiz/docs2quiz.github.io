---
import '../styles/theme.css'
import logo from '../assets/logo.png'
import demo from '../assets/demo.gif'
import { landing, type LandingLang } from '../i18n/landing'

interface Props {
	lang: LandingLang
}

const { lang } = Astro.props
const t = landing[lang]
const prefix = lang === 'id' ? '/id' : ''
const otherPrefix = lang === 'id' ? '' : '/id'
const githubUrl = 'https://github.com/iqbal-rahmatullah/docs-to-quiz'
const year = 2026
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>docs-to-quiz — {t.hero.tagline}</title>
		<meta name="description" content={t.hero.subline} />
		<link rel="icon" href="/favicon.png" />
	</head>
	<body>
		<a class="skip-link" href="#main">{lang === 'id' ? 'Langsung ke konten' : 'Skip to content'}</a>

		<header class="site-header">
			<div class="wrap header-inner">
				<a class="brand" href={`${prefix}/`}>
					<img src={logo.src} alt="" width="32" height="32" />
					<span>docs-to-quiz</span>
				</a>
				<nav class="header-nav" aria-label="Primary">
					<a href={`${prefix}/getting-started/introduction/`}>{t.nav.docs}</a>
					<a href={githubUrl}>{t.nav.github}</a>
					<a
						class="lang-switch"
						href={`${otherPrefix}/`}
						hreflang={lang === 'id' ? 'en' : 'id'}
						aria-label={lang === 'id' ? 'Switch to English' : 'Ganti ke Bahasa Indonesia'}
					>
						{t.nav.switchLang}
					</a>
				</nav>
			</div>
		</header>

		<main id="main">
			<section class="hero">
				<div class="wrap">
					<h1>{t.hero.tagline}</h1>
					<p class="subline">{t.hero.subline}</p>
					<div class="cta-row">
						<a class="btn btn-primary" href={`${prefix}/getting-started/installation/`}>{t.hero.ctaPrimary}</a>
						<a class="btn btn-secondary" href={githubUrl}>{t.hero.ctaSecondary}</a>
					</div>
					<img class="demo-gif" src={demo.src} alt={t.hero.demoAlt} width="720" height="438" />
				</div>
			</section>

			<section class="features">
				<div class="wrap">
					<h2>{t.features.title}</h2>
					<div class="feature-grid">
						{
							t.features.items.map((item) => (
								<div class="feature-card">
									<h3>{item.title}</h3>
									<p>{item.desc}</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="how-it-works">
				<div class="wrap">
					<h2>{t.howItWorks.title}</h2>
					<ol class="step-strip">
						{t.howItWorks.steps.map((step) => <li>{step}</li>)}
					</ol>
				</div>
			</section>

			<section class="quickstart">
				<div class="wrap">
					<h2>{t.quickstart.title}</h2>
					<details class="qs-tab" open>
						<summary>{t.quickstart.tabs.manual.label}</summary>
						<pre><code>{t.quickstart.tabs.manual.code}</code></pre>
					</details>
					<details class="qs-tab">
						<summary>{t.quickstart.tabs.devsh.label}</summary>
						<pre><code>{t.quickstart.tabs.devsh.code}</code></pre>
					</details>
					<details class="qs-tab">
						<summary>{t.quickstart.tabs.docker.label}</summary>
						<pre><code>{t.quickstart.tabs.docker.code}</code></pre>
					</details>
				</div>
			</section>

			<section class="warning-section">
				<div class="wrap">
					<div class="warning-callout">
						<h2>{t.warning.title}</h2>
						<p>{t.warning.body}</p>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="wrap footer-inner">
				<span>© {year} {t.footer.credit} · {t.footer.license}</span>
				<div class="footer-links">
					<a href={githubUrl}>{t.footer.github}</a>
					<a href={`${prefix}/getting-started/introduction/`}>{t.footer.docs}</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	:global(body) {
		margin: 0;
		font-family: 'Manrope', sans-serif;
		background: #f4f6fb;
		color: #182335;
	}
	h1, h2, h3 {
		font-family: 'Sora', sans-serif;
	}
	.wrap {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.skip-link {
		position: absolute;
		top: -48px;
		left: 12px;
		z-index: 100;
		background: #1357d2;
		color: #ffffff;
		padding: 10px 18px;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 700;
		transition: top 0.15s ease;
	}
	.skip-link:focus {
		top: 12px;
	}

	:focus-visible {
		outline: 2px solid #1357d2;
		outline-offset: 2px;
	}

	.site-header {
		border-bottom: 1px solid #e2e8f3;
		background: #ffffff;
	}
	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		font-weight: 700;
		font-family: 'Sora', sans-serif;
		color: #182335;
		text-decoration: none;
	}
	.brand img {
		border-radius: 8px;
	}
	.header-nav {
		display: flex;
		align-items: center;
		gap: 24px;
	}
	.header-nav a {
		color: #637083;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
	}
	.header-nav a:hover {
		color: #1d6bff;
	}
	.lang-switch {
		border: 1px solid #e2e8f3;
		border-radius: 20px;
		padding: 4px 12px;
	}

	.hero {
		padding: 72px 0 56px;
		text-align: center;
	}
	.hero h1 {
		font-size: clamp(1.75rem, 3.4vw, 2.5rem);
		line-height: 1.2;
		margin: 0 0 18px;
	}
	.subline {
		max-width: 600px;
		margin: 0 auto 32px;
		color: #637083;
		font-size: 1.05rem;
		line-height: 1.6;
	}
	.cta-row {
		display: flex;
		gap: 16px;
		justify-content: center;
		margin-bottom: 48px;
	}
	.btn {
		display: inline-block;
		padding: 12px 28px;
		border-radius: 10px;
		font-weight: 700;
		text-decoration: none;
		font-size: 1rem;
	}
	.btn-primary {
		background: #1d6bff;
		color: #ffffff;
	}
	.btn-primary:hover {
		background: #1357d2;
	}
	.btn-secondary {
		background: #ffffff;
		color: #182335;
		border: 1px solid #e2e8f3;
	}
	.demo-gif {
		max-width: 100%;
		width: 720px;
		border-radius: 16px;
		box-shadow: 0 20px 40px rgba(24, 35, 53, 0.12);
		border: 1px solid #e2e8f3;
	}

	.features {
		padding: 56px 0;
	}
	.features h2, .how-it-works h2, .quickstart h2 {
		text-align: center;
		font-size: 1.5rem;
		margin: 0 0 36px;
	}
	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}
	.feature-card {
		background: #ffffff;
		border: 1px solid #e2e8f3;
		border-radius: 14px;
		padding: 24px;
	}
	.feature-card h3 {
		margin: 0 0 10px;
		font-size: 1rem;
		color: #1357d2;
	}
	.feature-card p {
		margin: 0;
		color: #637083;
		line-height: 1.55;
		font-size: 0.95rem;
	}

	.how-it-works {
		padding: 40px 0 56px;
	}
	.step-strip {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 12px;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.step-strip li {
		background: #eef5ff;
		color: #1357d2;
		border-radius: 20px;
		padding: 8px 16px;
		font-weight: 600;
		font-size: 0.85rem;
		white-space: nowrap;
	}
	.step-strip li:not(:last-child)::after {
		content: '→';
		margin-left: 12px;
		color: #a9b6cc;
	}

	.quickstart {
		padding: 40px 0 56px;
	}
	.qs-tab {
		max-width: 700px;
		margin: 0 auto 12px;
		background: #182335;
		border-radius: 12px;
		overflow: hidden;
	}
	.qs-tab summary {
		cursor: pointer;
		padding: 14px 20px;
		font-weight: 700;
		color: #ffffff;
		list-style: none;
	}
	.qs-tab summary::-webkit-details-marker {
		display: none;
	}
	.qs-tab pre {
		margin: 0;
		padding: 0 20px 20px;
		overflow-x: auto;
	}
	.qs-tab code {
		color: #c8d3e8;
		font-size: 0.85rem;
		line-height: 1.6;
		white-space: pre;
	}

	.warning-section {
		padding: 0 0 56px;
	}
	.warning-callout {
		max-width: 700px;
		margin: 0 auto;
		background: var(--dtq-amber-bg);
		border: 1px solid #f0d8a8;
		border-left: 4px solid var(--dtq-amber);
		border-radius: 10px;
		padding: 18px 22px;
	}
	.warning-callout h2 {
		font-size: 1rem;
		color: var(--dtq-amber);
		margin: 0 0 6px;
	}
	.warning-callout p {
		margin: 0;
		color: #7a5a2e;
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.site-footer {
		border-top: 1px solid #e2e8f3;
		background: #ffffff;
		padding: 24px 0;
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 12px;
		color: #637083;
		font-size: 0.9rem;
	}
	.footer-links {
		display: flex;
		gap: 20px;
	}
	.footer-links a {
		color: #637083;
		text-decoration: none;
	}
	.footer-links a:hover {
		color: #1d6bff;
	}

	@media (max-width: 720px) {
		.feature-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
